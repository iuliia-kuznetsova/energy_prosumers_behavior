# =============================================================================
# Energy Prosumers Behavior Prediction - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp env.template .env
# =============================================================================

# -----------------------------------------------------------------------------
# Kaggle API Credentials
# Get your API key from: https://www.kaggle.com/settings
# Alternative: Create ~/.kaggle/kaggle.json with {"username":"xxx","key":"xxx"}
# -----------------------------------------------------------------------------
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# -----------------------------------------------------------------------------
# Random State (for reproducibility)
# -----------------------------------------------------------------------------
RANDOM_STATE=3112

# -----------------------------------------------------------------------------
# Directory Paths
# -----------------------------------------------------------------------------
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
MODELS_DIR=./models
RESULTS_DIR=./results

# -----------------------------------------------------------------------------
# Optuna Hyperparameter Optimization
# -----------------------------------------------------------------------------
OPTUNA_N_TRIALS=10
CV_SPLITS=3

# -----------------------------------------------------------------------------
# MLflow Configuration (optional - for experiment tracking)
# -----------------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000
# MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
